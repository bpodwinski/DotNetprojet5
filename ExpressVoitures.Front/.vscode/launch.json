    "version": "0.2.0",
    "configurations": [
        {
        "type": "node",
        "request": "launch",
        "name": "Next.js: dev",
        "runtimeExecutable": "npm",
        "runtimeArgs": [
            "run",
            "dev"
        ],
        "console": "integratedTerminal",
        "internalConsoleOptions": "neverOpen",
        "skipFiles": ["<node_internals>/**"]
        },
        {
        "type": "node",
        "request": "launch",
        "name": "Next.js: build",
        "runtimeExecutable": "npm",
        "runtimeArgs": [
            "run",
            "build"
        ],
        "console": "integratedTerminal",
        "internalConsoleOptions": "neverOpen",
        "skipFiles": ["<node_internals>/**"]
        },
        {
        "type": "node",
        "request": "launch",
        "name": "Next.js: start",
        "runtimeExecutable": "npm",
        "runtimeArgs": [
            "run",
            "start"
        ],
        "console": "integratedTerminal",
        "internalConsoleOptions": "neverOpen",
        "skipFiles": ["<node_internals>/**"]
        }
    ]
}